global:
  scrape_interval:     <%= ENV["PROMETHEUS_GLOBAL_SCRAPE_INTERVAL"] || "30s" %>
  evaluation_interval: <%= ENV["PROMETHEUS_GLOBAL_EVALUATION_INTERVAL"] || "30s" %>

remote_write:
  - url: "<%= ENV["SCALINGO_INFLUX_URL"] %>/write?db=<%= ENV["INFLUXDB_DB"] %>"

scrape_configs:
  # Get Prometheus self-metrics
  - job_name: "prometheus"
    basic_auth:
      username: "<%= ENV["BASIC_AUTH_USERNAME"] %>"
      password: "<%= ENV["BASIC_AUTH_PASSWORD"] %>"
    static_configs:
      - targets: ["<%= ENV["CANONICAL_HOST"] %>"]

  # Get user-defined metrics from environment variable
  <% JSON.parse(ENV["PROMETHEUS_SCRAPE_CONFIGS"]).each do |job| %>
  - job_name: "<%= job['job_name'] %>"
    scrape_interval: <%= job['scrape_interval'] || '15s' %>
    scrape_timeout: <%= job['scrape_timeout'] || '10s' %>
    metrics_path: <%= job['metrics_path'] || '/metrics' %>
    scheme: <%= job['scheme'] || 'https' %>
    <% if job['basic_auth'] %>
    basic_auth:
      username: "<%= job.dig('basic_auth', 'username') %>"
      password: "<%= job.dig('basic_auth', 'password') %>"
    <% end %>
    static_configs:
      - targets: <%= (job.dig('static_configs', 0, 'targets') || []).map { |t| t.gsub(%r{/metrics/?$}, '') }.to_json %>
        labels: <%= job.dig('static_configs', 0, 'labels') || {}.to_json %>
    <% if job['metric_relabel_configs'] %>
    metric_relabel_configs: <%= job['metric_relabel_configs'].to_json %>
    <% end %>
  <% end %>